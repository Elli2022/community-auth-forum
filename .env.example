# PostgreSQL (lokalt via docker compose, eller Neon i produktion)
DATABASE_URL=postgresql://auth:auth@localhost:5432/authms

NODE_HOSTNAME=127.0.0.1
NODE_PORT=3000
NODE_NAME=community-auth-forum
NODE_ENV=development

# JWT för inloggning (sätt starkt värde i produktion / Netlify)
JWT_SECRET=change-me-in-production

# Valfritt: filbaserad loggning
# NODE_LOG_PATH=./logs
